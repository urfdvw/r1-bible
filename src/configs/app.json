{
    "name": "app",
    "title": "设置",
    "type": "object",
    "properties": {
        "language": {
            "title": "圣经语言",
            "type": "string",
            "enum": ["中文", "English", "对照"],
            "default": "中文"
        },
        "chinese": {
            "title": "中文圣经版本",
            "type": "string",
            "enum": ["简体", "繁體"],
            "default": "简体"
        },
        "english": {
            "title": "英文圣经版本",
            "type": "string",
            "enum": ["KJV", "ASV", "WEB"],
            "default": "ASV"
        },
        "contrast_layout": {
            "title": "对照显示排版",
            "type": "string",
            "enum": ["前后", "并排"],
            "default": "前后"
        },
        "preview_font_size": {
            "title": "预览字号 (%)",
            "type": "integer",
            "default": 100
        },
        "disable_wheel": {
            "title": "禁用滚轮",
            "type": "string",
            "enum": ["是", "否"],
            "default": "否"
        },
        "theme": {
            "title": "主题",
            "type": "string",
            "enum": ["跟随系统", "白天", "夜间", "夜间投影"],
            "default": "跟随系统"
        },
        "show_tips_on_startup": {
            "title": "在启动时显示贴士",
            "type": "string",
            "enum": ["是", "否"],
            "default": "是"
        }
    }
}
